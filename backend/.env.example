# ============================================================
#  StudyBuddy — Environment Variables
# ============================================================
#  Copy this file to .env and fill in your values:
#     cp .env.example .env
# ============================================================

# ----------------------------------------------------------
#  Server
# ----------------------------------------------------------
PORT=5000

# ----------------------------------------------------------
#  MongoDB Atlas Connection
# ----------------------------------------------------------
#  HOW TO GET YOUR MONGODB ATLAS URI:
#
#  1. Go to https://www.mongodb.com/atlas and sign up / log in.
#
#  2. Create a FREE cluster:
#     • Click "Build a Database"
#     • Choose the FREE "M0" tier
#     • Pick a cloud provider & region closest to you
#     • Name your cluster (e.g., "StudyBuddyCluster")
#     • Click "Create Deployment"
#
#  3. Create a database user:
#     • In the "Security Quickstart" prompt, choose
#       "Username and Password"
#     • Enter a username (e.g., studybuddy_admin)
#     • Enter / auto‐generate a strong password
#     • Click "Create User"
#     • ⚠️  SAVE the password — you'll need it below
#
#  4. Allow network access:
#     • In the same quickstart (or go to Network Access),
#       click "Add My Current IP Address" for development
#     • Or add 0.0.0.0/0 to allow access from anywhere
#       (fine for development; restrict in production)
#
#  5. Get your connection string:
#     • Go to "Database" → click "Connect" on your cluster
#     • Choose "Drivers" → select "Node.js"
#     • Copy the connection string — it looks like:
#
#       mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
#
#     • Replace <username> with your DB username
#     • Replace <password> with your DB password
#     • Add a database name before the ? :
#
#       mongodb+srv://studybuddy_admin:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/studybuddy?retryWrites=true&w=majority
#
#  6. Paste the final URI below:
# ----------------------------------------------------------

MONGO_URI=

# ----------------------------------------------------------
#  JWT (JSON Web Token)
# ----------------------------------------------------------
#  Generate a random secret (e.g., run in terminal):
#     node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
#
#  Or just use a long, random string of your choice.
# ----------------------------------------------------------

JWT_SECRET=your_jwt_secret_change_this_in_production
